{
    "name": "yisraeldov/composer-subtree-plugin",
    "description": "Composer plugin for safer git subtree workflows",
    "type": "composer-plugin",
    "license": "MIT",
    "require": {
        "composer-plugin-api": "^2.2",
        "php": "^8.2"
    },
    "require-dev": {
        "composer/composer": "^2.9",
        "friendsofphp/php-cs-fixer": "^3.95",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpactor/phpactor": "^2025.03@dev",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "ComposerSubtreePlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ComposerSubtreePlugin\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "parallel-lint src tests",
        "cs": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --verbose",
        "cs:fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --verbose",
        "phpcs": "phpcs --standard=phpcs.xml.dist src tests",
        "phpcs:fix": "phpcbf --standard=phpcs.xml.dist",
        "phpmd": "phpmd src text phpmd.xml.dist",
        "phpstan": "phpstan analyse --configuration=phpstan.neon --no-progress",
        "test": "phpunit --configuration=phpunit.xml.dist",
        "qa": [
            "@lint",
            "@cs",
            "@phpcs",
            "@phpmd",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2.0"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "class": "ComposerSubtreePlugin\\Plugin"
    }
}
